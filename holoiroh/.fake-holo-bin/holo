#!/usr/bin/env bash
# Fake `holo` CLI stand-in: only implements `holo serve --port N`, enough to
# exercise HoloBridge::start()'s health+agent-card probe for a witnessed test
# run of the control channel. Not a real Holo3 agent.
set -euo pipefail
if [ "${1:-}" = "serve" ]; then
    shift
    exec python3 "$(dirname "$0")/fake_holo_serve.py" "$@"
fi
echo "fake holo: unsupported subcommand: $*" >&2
exit 1
